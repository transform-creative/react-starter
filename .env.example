# Public (Vite-exposed) — bundled into the client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# Brand (optional, surfaced in emails and BrandConfig fallback)
BRAND_NAME=

# Edge function secrets — set via `supabase secrets set` for deployed projects.
# Stripe
STRIPE_SECRET_KEY=

# Rate limiting (optional — stripe-checkout skips rate-limiting if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Image moderation (Google Vision SafeSearch)
GOOGLE_VISION_API_KEY=

# Transactional email provider (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Supabase service role key (only used by edge functions internally)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
